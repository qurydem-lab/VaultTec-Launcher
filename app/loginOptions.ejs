<div id="loginOptionsContainer" style="display: none;">
    <div id="loginOptionsContent">
        <div class="loginOptionsMainContent">
            <h2>Sign in to Vault-Tec</h2>
            <div class="loginOptionActions">
                <div class="loginOptionButtonContainer">
                    <button id="loginOptionElyBy" class="loginOptionButton">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="12" fill="#1E88E5"/>
                            <text x="12" y="16" text-anchor="middle" fill="white" font-size="10" font-family="Arial" font-weight="bold">ely</text>
                        </svg>
                        <span>Sign in with Ely.by</span>
                    </button>
                </div>
                <div class="loginOptionButtonContainer" style="margin-top: 8px;">
                    <a href="https://ely.by/register" style="color: #aaa; font-size: 12px; text-decoration: none;">
                        Don't have an account? Register on Ely.by
                    </a>
                </div>
            </div>
            <div id="loginOptionCancelContainer" style="display: none;">
                <button id="loginOptionCancelButton"><%- lang('loginOptions.cancelButton') %></button>
            </div>
        </div>
    </div>
    <script src="./assets/js/scripts/loginOptions.js"></script>
</div>